generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["arbre"]
}

model Log {
  id        String   @id @default(uuid())
  timestamp DateTime
  level     String
  message   String?
  scope     String?
  payload   Json?

  @@map("log")
  @@schema("arbre")
}
